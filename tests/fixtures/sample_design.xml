<?xml version="1.0" encoding="UTF-8"?>
<IPC-2581 revision="C">
  <Content>
    <Units unitType="MM"/>
    <Step name="TestBoard">
      <Profile>
        <Polygon>
          <PolyBegin x="0" y="0"/>
          <PolyStepSegment x="80" y="0"/>
          <PolyStepSegment x="80" y="60"/>
          <PolyStepSegment x="0" y="60"/>
          <PolyStepSegment x="0" y="0"/>
        </Polygon>
      </Profile>
    </Step>
  </Content>

  <Ecad name="TestECAD"/>

  <StackupGroup name="standard_4layer">
    <StackupLayer layerOrGroupRef="TOP" layerFunctionType="SIGNAL" thickness="0.035" material="Copper" copperWeight="1.0"/>
    <StackupLayer layerOrGroupRef="DIELECTRIC1" layerFunctionType="DIELECTRIC" thickness="0.2" material="FR4" dielectricConstant="4.5"/>
    <StackupLayer layerOrGroupRef="GND" layerFunctionType="PLANE" thickness="0.035" material="Copper" copperWeight="1.0"/>
    <StackupLayer layerOrGroupRef="CORE" layerFunctionType="DIELECTRIC" thickness="1.0" material="FR4" dielectricConstant="4.5"/>
    <StackupLayer layerOrGroupRef="PWR" layerFunctionType="PLANE" thickness="0.035" material="Copper" copperWeight="1.0"/>
    <StackupLayer layerOrGroupRef="DIELECTRIC2" layerFunctionType="DIELECTRIC" thickness="0.2" material="FR4" dielectricConstant="4.5"/>
    <StackupLayer layerOrGroupRef="BOTTOM" layerFunctionType="SIGNAL" thickness="0.035" material="Copper" copperWeight="1.0"/>
  </StackupGroup>

  <Net name="GND">
    <PinRef componentRef="U1" pin="1"/>
    <PinRef componentRef="C1" pin="2"/>
    <PinRef componentRef="C2" pin="2"/>
  </Net>
  <Net name="VCC_3V3">
    <PinRef componentRef="U1" pin="2"/>
    <PinRef componentRef="C1" pin="1"/>
    <PinRef componentRef="U4" pin="2"/>
  </Net>
  <Net name="USB_D_P">
    <PinRef componentRef="U1" pin="10"/>
    <PinRef componentRef="J1" pin="A6"/>
  </Net>
  <Net name="USB_D_N">
    <PinRef componentRef="U1" pin="11"/>
    <PinRef componentRef="J1" pin="A7"/>
  </Net>
  <Net name="SPI_CLK">
    <PinRef componentRef="U1" pin="20"/>
    <PinRef componentRef="U3" pin="1"/>
  </Net>

  <Component refDes="U1" packageRef="BGA-256" layerRef="TOP" mountType="SMD">
    <Location x="40" y="30" rotation="0"/>
  </Component>
  <Component refDes="U3" packageRef="SSOP-28" layerRef="TOP" mountType="SMD">
    <Location x="15" y="15" rotation="0"/>
  </Component>
  <Component refDes="U4" packageRef="SOT-223" layerRef="TOP" mountType="SMD">
    <Location x="70" y="15" rotation="0"/>
  </Component>
  <Component refDes="C1" packageRef="C_0402" layerRef="TOP" mountType="SMD">
    <Location x="35" y="28" rotation="0"/>
  </Component>
  <Component refDes="C2" packageRef="C_0402" layerRef="TOP" mountType="SMD">
    <Location x="45" y="28" rotation="0"/>
  </Component>
  <Component refDes="J1" packageRef="USB_C" layerRef="TOP" mountType="SMD">
    <Location x="0" y="30" rotation="0"/>
  </Component>
  <Component refDes="R1" packageRef="R_0402" layerRef="TOP" mountType="SMD">
    <Location x="55" y="20" rotation="0"/>
  </Component>
  <Component refDes="R2" packageRef="R_0402" layerRef="BOTTOM" mountType="SMD">
    <Location x="55" y="25" rotation="0"/>
  </Component>

  <LayerFeature layerRef="TOP">
    <Line startX="0" startY="30" endX="15" endY="15" width="0.15" net="USB_D_P"/>
    <Line startX="0" startY="31" endX="15" endY="16" width="0.15" net="USB_D_N"/>
    <Line startX="15" startY="15" endX="40" endY="30" width="0.15" net="USB_D_P"/>
    <Line startX="40" startY="30" endX="55" endY="20" width="0.2" net="SPI_CLK"/>
    <Line startX="70" startY="15" endX="60" endY="20" width="0.3" net="VCC_3V3"/>
  </LayerFeature>

  <LayerFeature layerRef="BOTTOM">
    <Line startX="10" startY="50" endX="15" endY="50" width="0.2" net="GND"/>
  </LayerFeature>

  <Via x="15" y="15" padstackDefRef="VIA_STD" net="USB_D_P"/>
  <Via x="35" y="28" padstackDefRef="VIA_STD" net="GND"/>
  <Via x="45" y="28" padstackDefRef="VIA_STD" net="GND"/>

  <PadStackDef name="VIA_STD">
    <Hole diameter="0.3"/>
  </PadStackDef>

  <Package name="BGA-256">
    <Pad number="1" x="-6.5" y="-6.5" padstackDefRef="BGA_PAD"/>
    <Pad number="2" x="-5.7" y="-6.5" padstackDefRef="BGA_PAD"/>
  </Package>
  <Package name="SSOP-28">
    <Pad number="1" x="-3.5" y="-4.5" padstackDefRef="SMD_PAD"/>
  </Package>

  <Rule name="min_trace_width" type="WIDTH" value="0.1" unit="MM"/>
  <Rule name="min_clearance" type="CLEARANCE" value="0.1" unit="MM"/>
  <Rule name="min_drill" type="DRILL" value="0.2" unit="MM"/>

